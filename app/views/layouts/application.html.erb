<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content_for(:title) || "Prompt" %></title>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="h-full bg-gray-50">
  <nav class="bg-white shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <div class="flex items-center space-x-6">
          <%= link_to "Prompt", current_user ? user_dashboard_path : root_path, class: "text-xl font-bold text-indigo-600" %>
          <% if current_user %>
            <%= link_to "Dashboard", user_dashboard_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600" %>
            <% if current_user.property_manager? %>
              <%= link_to "Properties", web_manager_properties_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600" %>
              <%= link_to "Tenants", web_manager_tenants_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600" %>
              <%= link_to "Vendors", web_manager_vendors_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600" %>
              <%= link_to "Maintenance Requests", web_manager_maintenance_requests_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600" %>
            <% end %>
            <% if current_user.super_admin? %>
              <%= link_to "Users", web_admin_users_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600" %>
              <%= link_to "Properties", web_admin_properties_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600" %>
              <%= link_to "Requests", web_admin_maintenance_requests_path, class: "text-sm font-medium text-gray-600 hover:text-indigo-600" %>
            <% end %>
          <% end %>
        </div>
        <div class="flex items-center space-x-4">
          <% if current_user %>
            <% profile_path = current_user.property_manager? ? edit_web_manager_profile_path : web_preferences_path %>
            <%= link_to current_user.name, profile_path, class: "text-gray-700 text-sm hover:text-indigo-600" %>
            <%= button_to "Log out", logout_path, method: :delete, form_class: "flex items-center", class: "text-sm text-gray-500 hover:text-gray-700 bg-transparent border-0 p-0 m-0 cursor-pointer" %>
          <% else %>
            <%= link_to "Log in", login_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <% if flash[:notice] %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-md bg-green-50 p-4">
        <p class="text-sm text-green-800"><%= flash[:notice] %></p>
      </div>
    </div>
  <% end %>

  <% if flash[:alert] %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
      <div class="rounded-md bg-red-50 p-4">
        <p class="text-sm text-red-800"><%= flash[:alert] %></p>
      </div>
    </div>
  <% end %>

  <main>
    <%= yield %>
  </main>

  <footer class="bg-white border-t mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex justify-between items-center">
        <p class="text-gray-400 text-sm">&copy; <%= Date.current.year %> Prompt. All rights reserved.</p>
        <div class="space-x-4">
          <%= link_to "Privacy", privacy_path, class: "text-sm text-gray-400 hover:text-gray-600" %>
          <%= link_to "Terms", terms_path, class: "text-sm text-gray-400 hover:text-gray-600" %>
        </div>
      </div>
    </div>
  </footer>
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      document.querySelectorAll("time[datetime]").forEach(function(el) {
        var d = new Date(el.getAttribute("datetime"));
        var fmt = el.dataset.format;
        var dateStr = (d.getMonth()+1).toString().padStart(2,"0") + "/" + d.getDate().toString().padStart(2,"0") + "/" + d.getFullYear().toString().slice(-2);
        var timeStr = d.toLocaleTimeString(undefined, { hour: "numeric", minute: "2-digit" });
        if (fmt === "datetime_ago") {
          var now = new Date();
          var diffMs = now - d;
          var diffMins = Math.floor(diffMs / 60000);
          var ago;
          if (diffMins < 1) { ago = "just now"; }
          else if (diffMins < 60) { ago = diffMins + " minute" + (diffMins === 1 ? "" : "s") + " ago"; }
          else if (diffMins < 1440) { var h = Math.floor(diffMins/60); ago = h + " hour" + (h === 1 ? "" : "s") + " ago"; }
          else { var dy = Math.floor(diffMins/1440); ago = dy + " day" + (dy === 1 ? "" : "s") + " ago"; }
          el.textContent = dateStr + " " + timeStr + " \u2014 " + ago;
        } else if (fmt === "datetime") {
          el.textContent = dateStr + " " + timeStr;
        } else if (fmt === "short_date") {
          el.textContent = d.toLocaleDateString(undefined, { month: "short", day: "numeric" });
        } else if (fmt === "long_date") {
          el.textContent = d.toLocaleDateString(undefined, { month: "long", day: "numeric", year: "numeric" });
        } else {
          el.textContent = d.toLocaleDateString(undefined, { month: "short", day: "numeric", year: "numeric" });
        }
      });
    });
  </script>
</body>
</html>
