<% content_for(:title) { "My Profile - Prompt" } %>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">My Profile</h1>
    <%= link_to "Back to Dashboard", web_manager_dashboard_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
  </div>

  <%= form_with url: web_manager_profile_path, method: :patch, class: "space-y-6" do |f| %>
    <%# Personal Info %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Personal Information</h2>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
          <%= f.text_field :name, name: "user[name]", value: current_user.name,
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border",
              placeholder: "Your full name" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone Number</label>
          <%= f.telephone_field :phone, name: "user[phone]", value: current_user.phone,
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border",
              placeholder: "(212) 555-1234" %>
        </div>
      </div>
    </div>

    <%# Email %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Email Address</h2>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        <%= f.email_field :email, name: "user[email]", value: current_user.email,
            class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border",
            placeholder: "you@example.com" %>
      </div>
    </div>

    <%# Password Change %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-1">Change Password</h2>
      <p class="text-sm text-gray-500 mb-4">Leave blank to keep your current password.</p>
      <div class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Current Password</label>
          <%= password_field_tag :current_password,
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border",
              placeholder: "Enter current password to change it",
              autocomplete: "current-password" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
          <%= f.password_field :password, name: "user[password]",
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border",
              placeholder: "New password (min 8 characters)",
              autocomplete: "new-password" %>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Confirm New Password</label>
          <%= f.password_field :password_confirmation, name: "user[password_confirmation]",
              class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 text-sm py-2 px-3 border",
              placeholder: "Confirm new password",
              autocomplete: "new-password" %>
        </div>
      </div>
    </div>

    <%# Account Info (read-only) %>
    <div class="bg-white shadow rounded-lg p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Account</h2>
      <div class="space-y-3">
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Account Type</p>
          <p class="mt-1 text-sm text-gray-900"><%= current_user.role.humanize %></p>
        </div>
        <div>
          <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Member Since</p>
          <p class="mt-1 text-sm text-gray-900"><%= current_user.created_at.strftime("%B %Y") %></p>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-end gap-3">
      <%= link_to "Cancel", web_manager_dashboard_path, class: "text-sm text-gray-600 hover:text-gray-800" %>
      <%= f.submit "Save Changes", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 cursor-pointer" %>
    </div>
  <% end %>
</div>
